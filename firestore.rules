rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       HELPERS
    ========================= */
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }

    function isAgent() {
      return isAuthenticated() && getUserData().role == 'agent';
    }

    function isSupervisor() {
      return isAuthenticated() && getUserData().role == 'supervisor';
    }

    function isActive() {
      return getUserData().status == 'active';
    }

    /* =========================
       USERS
    ========================= */
    match /users/{userId} {

      // 🔐 ADMIN : accès total
      allow read, write: if isAdmin() && isActive();

      // 👤 Utilisateur : lire son propre profil
      allow read: if isAuthenticated()
                  && isActive()
                  && request.auth.uid == userId;

      // ➕ Création du profil à l’inscription
      allow create: if isAuthenticated()
                    && request.auth.uid == userId;

      // ➕ Création alternative (par sécurité)
      allow create: if isAuthenticated()
                    && request.resource.data.uid == request.auth.uid;
    }

    /* =========================
       PROSPECTION FORMS
    ========================= */
    match /prospection_forms/{formId} {
      allow read: if isAuthenticated() && isActive();
      allow write: if isAdmin() && isActive();
    }

    /* =========================
       PROSPECTS (PRIVÉ AGENT)
    ========================= */
    match /prospects/{prospectId} {

      allow read: if isAgent()
                  && isActive()
                  && request.auth.uid == resource.data.agentId;

      allow create: if isAgent()
                    && isActive()
                    && request.auth.uid == request.resource.data.agentId;

      allow update: if isAgent()
                    && isActive()
                    && request.auth.uid == request.resource.data.agentId;

      allow delete: if isAgent()
                    && isActive()
                    && request.auth.uid == request.resource.data.agentId;
    }

    /* =========================
       CLIENTS
    ========================= */
    match /clients/{clientId} {

      allow read: if isAuthenticated() && isActive();

      allow create: if isAgent()
                    && isActive()
                    && request.auth.uid == request.resource.data.agentId;

      allow update, delete: if false;
    }

    /* =========================
       SALES
    ========================= */
    match /sales/{saleId} {
      allow read: if isAuthenticated() && isActive();
      allow write: if isAdmin() && isActive();
    }

    /* =========================
       COMMISSIONS
    ========================= */
    match /commissions/{commissionId} {
      allow read: if isAuthenticated() && isActive();
      allow write: if isAdmin() && isActive();
    }

    /* =========================
       SYSTEM CONFIG
    ========================= */
    match /system_config/{configId} {

      // 🔓 Lecture publique UNIQUEMENT du code d’accès agent
      allow read: if configId == 'agent_access_code';

      // 🔐 Écriture réservée aux admins actifs
      allow write: if isAdmin() && isActive();
    }

    /* =========================
       FORMS (désactivé)
    ========================= */
    match /forms/{formId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;
    }
  }
}
